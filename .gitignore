# See https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# ── Python ──────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
build/
dist/
.eggs/
*.so

# Virtualenvs / installed packages
.venv/
venv/
env/
.pythonlibs/

# Testing & linting caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml

# Build outputs
*.egg
pip-wheel-metadata/

# ── Environment ─────────────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ── Editors / IDEs ──────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*.sublime-workspace
*.sublime-project
.DS_Store
Thumbs.db

# ── Replit ──────────────────────────────────────────────────────────────
.cache/
.local/
.upm/

# ── Arcana runtime data ─────────────────────────────────────────────────
# Per-bot virtualenvs and Builder Agent sandbox workspaces.
runtime_envs/
arcana/runtime_envs/*
!arcana/runtime_envs/.gitkeep

# ── Node / pnpm leftovers (kept out of this Python project) ────────────
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml
*.tsbuildinfo
